# Google Gemini API Key for multi-agent LLM orchestration
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API Key for geolocation and travel distance calculations
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: override DB (default is /tmp/ustaad.db for Cloud Run; use ./ustaad.db for local dev)
DATABASE_URL=sqlite:////tmp/ustaad.db

# Optional: comma-separated origins allowed by backend CORS middleware
CORS_ALLOW_ORIGINS=http://localhost:8550,http://127.0.0.1:8550

# Optional: frontend endpoint target (for local runs of frontend/main.py)
USTAAD_API_URL=http://localhost:8000
